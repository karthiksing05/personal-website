    <item>
      <title>Artifact 2</title>
      <link>//localhost:1313/school/engl1102/artifact2/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/school/engl1102/artifact2/</guid>
      <description>&lt;!DOCTYPE html&gt;&#xA;&lt;html lang=&#34;en&#34;&gt;&#xA;&lt;head&gt;&#xA;&lt;meta charset=&#34;UTF-8&#34;&gt;&#xA;&lt;meta name=&#34;viewport&#34; content=&#34;width=device-width, initial-scale=1.0&#34;&gt;&#xA;&lt;meta name=&#34;robots&#34; content=&#34;noindex, nofollow&#34;&gt;&#xA;&lt;title&gt;Yelling Through the Whispers&lt;/title&gt;&#xA;&lt;link href=&#34;https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&amp;family=Source+Serif+4:ital,wght@0,300;0,400;0,600;1,400&amp;family=Inter:wght@300;400;500;600&amp;display=swap&#34; rel=&#34;stylesheet&#34;&gt;&#xA;&lt;style&gt;&#xA;  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }&#xA;  :root { --saffron: #FF9933; --green: #138808; --bg: #f5f3ef; --text: #1a1a1a; --muted: #6b6b6b; --rule: #d0ccc4; }&#xA;  html { scroll-behavior: smooth; }&#xA;  body { background: var(--bg); color: var(--text); font-family: &#39;Source Serif 4&#39;, Georgia, serif; font-size: 18px; line-height: 1.85; }&#xA;&#xA;  #progress-bar { position: fixed; top: 0; left: 0; height: 3px; background: linear-gradient(90deg, var(--saffron), var(--green)); width: 0%; z-index: 1000; transition: width 0.1s linear; }&#xA;&#xA;  /* HERO */&#xA;  #hero { position: relative; width: 100%; height: 100vh; min-height: 580px; overflow: hidden; display: flex; align-items: center; justify-content: center; }&#xA;  .banner-halves { position: absolute; inset: 0; display: flex; }&#xA;  .banner-half { flex: 1; background-size: cover; background-position: center; filter: grayscale(1) brightness(0.42); background-color: #1a1a1a; }&#xA;  .banner-half.left { background-position: center top; }&#xA;&#xA;  .lightning-divider { position: absolute; top: 0; bottom: 0; left: 50%; transform: translateX(-50%); width: 64px; z-index: 3; display: flex; align-items: stretch; justify-content: center; }&#xA;  .lightning-divider svg { width: 64px; height: 100%; filter: drop-shadow(0 0 10px var(--saffron)) drop-shadow(0 0 22px rgba(255,255,255,0.4)); }&#xA;  .banner-overlay { position: absolute; inset: 0; background: radial-gradient(ellipse at center, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.74) 100%); z-index: 2; }&#xA;&#xA;  .hero-content { position: relative; z-index: 4; text-align: center; color: #fff; padding: 0 24px; max-width: 880px; }&#xA;  .hero-eyebrow { font-family: &#39;Inter&#39;, sans-serif; font-size: 11px; font-weight: 500; letter-spacing: 0.35em; text-transform: uppercase; color: var(--saffron); margin-bottom: 22px; }&#xA;  .hero-content h1 { font-family: &#39;Playfair Display&#39;, serif; font-size: clamp(2.8rem, 7.5vw, 6.2rem); font-weight: 900; line-height: 1.04; letter-spacing: -0.01em; text-shadow: 0 2px 36px rgba(0,0,0,0.75); margin-bottom: 20px; }&#xA;  .hero-content h1 em { font-style: italic; color: var(--saffron); }&#xA;  .hero-sub { font-family: &#39;Source Serif 4&#39;, serif; font-size: clamp(0.95rem, 2vw, 1.2rem); font-style: italic; font-weight: 300; color: #ddd; margin-bottom: 32px; max-width: 600px; margin-left: auto; margin-right: auto; }&#xA;  .hero-byline { font-family: &#39;Inter&#39;, sans-serif; font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase; color: #fff; border-top: 1px solid rgba(255,255,255,0.18); padding-top: 18px; display: inline-block; }&#xA;&#xA;  .banner-label { position: absolute; bottom: 28px; z-index: 5; font-family: &#39;Inter&#39;, sans-serif; font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255,255,255,0.45); }&#xA;  .banner-label.ll { left: 20px; } .banner-label.rl { right: 20px; }&#xA;  .flag-stripe { position: absolute; bottom: 0; left: 0; right: 0; height: 4px; background: linear-gradient(90deg, var(--saffron) 33.3%, #fff 33.3%, #fff 66.6%, var(--green) 66.6%); z-index: 6; }&#xA;&#xA;  /* ARTICLE */&#xA;  #article { max-width: 720px; margin: 0 auto; padding: 72px 24px 48px; }&#xA;  .intro-para { font-size: 1.12em; color: #222; border-left: 3px solid var(--saffron); padding-left: 20px; margin-bottom: 40px; }&#xA;  p { margin-bottom: 1.65em; }&#xA;&#xA;  .section-rule { display: flex; align-items: center; gap: 16px; margin: 52px 0 28px; }&#xA;  .section-rule::before, .section-rule::after { content: &#39;&#39;; flex: 1; height: 1px; background: var(--rule); }&#xA;  .section-rule span { font-family: &#39;Inter&#39;, sans-serif; font-size: 10px; letter-spacing: 0.3em; text-transform: uppercase; color: var(--muted); white-space: nowrap; }&#xA;&#xA;  /* PULL QUOTES */&#xA;  .pull-quote { margin: 52px -44px; padding: 38px 52px; background: #111; color: #fff; position: relative; overflow: hidden; opacity: 0; transform: translateX(-60px); transition: opacity 0.8s ease, transform 0.8s ease; }&#xA;  .pull-quote.fr { transform: translateX(60px); }&#xA;  .pull-quote.visible { opacity: 1; transform: translateX(0); }&#xA;  .pull-quote::before { content: &#39;\201C&#39;; position: absolute; top: -22px; left: 26px; font-size: 9rem; font-family: &#39;Playfair Display&#39;, serif; color: var(--saffron); opacity: 0.22; line-height: 1; }&#xA;  .pull-quote blockquote { font-family: &#39;Playfair Display&#39;, serif; font-size: clamp(1.08rem, 2.2vw, 1.42rem); font-style: italic; line-height: 1.52; position: relative; z-index: 1; margin-bottom: 14px; }&#xA;  .pull-quote cite { font-family: &#39;Inter&#39;, sans-serif; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--saffron); font-style: normal; }&#xA;&#xA;  /* IMAGE BLOCKS */&#xA;  .img-block { margin: 36px 0; opacity: 0; transform: translateX(60px); transition: opacity 0.8s ease, transform 0.8s ease; }&#xA;  .img-block.fl { transform: translateX(-60px); }&#xA;  .img-block.visible { opacity: 1; transform: translateX(0); }&#xA;&#xA;  .img-wrap { width: 100%; min-height: 240px; background: #1c1c1c; border: 1px solid #333; position: relative; overflow: hidden; display: flex; align-items: center; justify-content: center; }&#xA;  .img-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; position: absolute; inset: 0; filter: grayscale(1); }&#xA;  .img-block.color .img-wrap img { filter: none; }&#xA;&#xA;  /* Fallback shown until image loads or on error */&#xA;  .img-fallback { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px; padding: 32px; text-align: center; z-index: 1; }&#xA;  .img-fallback svg { opacity: 0.25; }&#xA;  .img-fallback span { font-family: &#39;Inter&#39;, sans-serif; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: #666; max-width: 260px; line-height: 1.6; }&#xA;  .img-fallback .dl-link { font-size: 10px; color: var(--saffron); text-decoration: underline; margin-top: 4px; word-break: break-all; }&#xA;&#xA;  /* Hide fallback once image loads */&#xA;  .img-wrap img.loaded + .img-fallback { display: none; }&#xA;&#xA;  figcaption { font-family: &#39;Inter&#39;, sans-serif; font-size: 12px; color: var(--muted); margin-top: 10px; padding-left: 10px; border-left: 2px solid var(--saffron); line-height: 1.55; }&#xA;&#xA;  /* STATS */&#xA;  .stat-strip { display: grid; grid-template-columns: repeat(3,1fr); gap: 1px; background: var(--rule); margin: 44px 0; opacity: 0; transform: translateY(28px); transition: opacity 0.8s ease, transform 0.8s ease; }&#xA;  .stat-strip.visible { opacity: 1; transform: translateY(0); }&#xA;  .stat-cell { background: var(--bg); padding: 24px 14px; text-align: center; }&#xA;  .stat-num { font-family: &#39;Playfair Display&#39;, serif; font-size: 2.2rem; font-weight: 900; color: var(--saffron); display: block; line-height: 1; margin-bottom: 7px; }&#xA;  .stat-label { font-family: &#39;Inter&#39;, sans-serif; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); }&#xA;&#xA;  /* TIMELINE */&#xA;  .timeline { margin: 44px 0; border-left: 2px solid var(--rule); padding-left: 28px; }&#xA;  .tl-item { position: relative; margin-bottom: 24px; opacity: 0; transform: translateX(-18px); transition: opacity 0.6s ease, transform 0.6s ease; }&#xA;  .tl-item.visible { opacity: 1; transform: translateX(0); }&#xA;  .tl-item::before { content: &#39;&#39;; position: absolute; left: -35px; top: 7px; width: 10px; height: 10px; border-radius: 50%; background: var(--saffron); }&#xA;  .tl-year { font-family: &#39;Inter&#39;, sans-serif; font-size: 11px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--saffron); margin-bottom: 4px; }&#xA;  .tl-text { font-size: 0.93em; color: #333; line-height: 1.65; }&#xA;&#xA;  .hl { color: var(--saffron); font-weight: 600; }&#xA;  .hlg { color: var(--green); font-weight: 600; }&#xA;  .ornament { text-align: center; color: var(--saffron); font-size: 1.3rem; margin: 48px 0; letter-spacing: 0.5em; opacity: 0.45; }&#xA;&#xA;  /* AUTHOR */&#xA;  #author { background: #f0ede8; border-top: 3px solid var(--saffron); padding: 52px 24px; }&#xA;  .author-inner { max-width: 720px; margin: 0 auto; display: flex; gap: 28px; align-items: flex-start; }&#xA;  .author-avatar { width: 68px; height: 68px; border-radius: 50%; background: #111; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-family: &#39;Playfair Display&#39;, serif; font-size: 1.7rem; color: var(--saffron); }&#xA;  .author-label { font-family: &#39;Inter&#39;, sans-serif; font-size: 10px; letter-spacing: 0.3em; text-transform: uppercase; color: var(--muted); margin-bottom: 5px; }&#xA;  .author-name { font-family: &#39;Playfair Display&#39;, serif; font-size: 1.22rem; font-weight: 700; margin-bottom: 9px; }&#xA;  .author-bio { font-size: 0.88em; color: #555; font-family: &#39;Inter&#39;, sans-serif; line-height: 1.72; }&#xA;&#xA;  /* SOURCES */&#xA;  #sources { background: #111; color: #ccc; padding: 64px 24px; margin-top: 72px; }&#xA;  .sources-inner { max-width: 720px; margin: 0 auto; }&#xA;  .sources-inner h3 { font-family: &#39;Inter&#39;, sans-serif; font-size: 10px; letter-spacing: 0.35em; text-transform: uppercase; color: var(--saffron); margin-bottom: 28px; }&#xA;  .source-item { display: flex; gap: 14px; margin-bottom: 16px; font-family: &#39;Inter&#39;, sans-serif; font-size: 12.5px; line-height: 1.68; color: #999; border-bottom: 1px solid #222; padding-bottom: 14px; }&#xA;  .source-item:last-child { border-bottom: none; padding-bottom: 0; }&#xA;  .source-num { color: var(--saffron); font-weight: 600; min-width: 22px; flex-shrink: 0; }&#xA;  .source-item a { color: #bbb; text-decoration: underline; word-break: break-all; }&#xA;&#xA;  @media (max-width: 620px) {&#xA;    .pull-quote { margin: 44px -8px; padding: 28px 24px; }&#xA;    .stat-strip { grid-template-columns: 1fr; }&#xA;    .author-inner { flex-direction: column; }&#xA;    #article { padding: 44px 18px 36px; }&#xA;    .banner-label { display: none; }&#xA;  }&#xA;&lt;/style&gt;&#xA;&lt;/head&gt;&#xA;&lt;body&gt;&#xA;&#xA;&lt;div id=&#34;progress-bar&#34;&gt;&lt;/div&gt;&#xA;&#xA;&lt;!-- HERO --&gt;&#xA;&lt;section id=&#34;hero&#34;&gt;&#xA;  &lt;div class=&#34;banner-halves&#34;&gt;&#xA;    &lt;div class=&#34;banner-half left&#34; id=&#34;bannerLeft&#34;&gt;&lt;/div&gt;&#xA;    &lt;div class=&#34;banner-half right&#34; id=&#34;bannerRight&#34;&gt;&lt;/div&gt;&#xA;  &lt;/div&gt;&#xA;  &lt;div class=&#34;lightning-divider&#34;&gt;&#xA;    &lt;svg viewBox=&#34;0 0 64 900&#34; preserveAspectRatio=&#34;none&#34; xmlns=&#34;http://www.w3.org/2000/svg&#34;&gt;&#xA;      &lt;line x1=&#34;32&#34; y1=&#34;0&#34; x2=&#34;32&#34; y2=&#34;900&#34; stroke=&#34;rgba(255,153,51,0.15)&#34; stroke-width=&#34;32&#34;/&gt;&#xA;      &lt;polyline points=&#34;42,0 24,180 44,180 20,360 42,360 18,540 40,540 22,720 42,720 24,900&#34; fill=&#34;none&#34; stroke=&#34;#FF9933&#34; stroke-width=&#34;3.8&#34; stroke-linejoin=&#34;round&#34; stroke-linecap=&#34;round&#34;/&gt;&#xA;      &lt;polyline points=&#34;42,0 24,180 44,180 20,360 42,360 18,540 40,540 22,720 42,720 24,900&#34; fill=&#34;none&#34; stroke=&#34;rgba(255,255,255,0.5)&#34; stroke-width=&#34;1.3&#34; stroke-linejoin=&#34;round&#34; stroke-linecap=&#34;round&#34;/&gt;&#xA;    &lt;/svg&gt;&#xA;  &lt;/div&gt;&#xA;  &lt;div class=&#34;banner-overlay&#34;&gt;&lt;/div&gt;&#xA;  &lt;div class=&#34;hero-content&#34;&gt;&#xA;    &lt;h1&gt;Yelling Through&lt;br&gt;the &lt;em&gt;Whispers&lt;/em&gt;&lt;/h1&gt;&#xA;    &lt;p class=&#34;hero-sub&#34;&gt;What India&#39;s Largest Monuments Reveal About India&#39;s Hidden Agenda&lt;/p&gt;</description>
    </item>
